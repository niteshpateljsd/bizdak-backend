# Database
# Add ?connection_limit=5 on Render/Railway free tier to avoid memory exhaustion
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bizdak"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Firebase
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"

# Cloudinary (image uploads for deals and stores)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins for the admin dashboard
# Production: CORS_ORIGINS=https://admin.bizdak.app
# Development: CORS_ORIGINS=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Admin credentials
# SECURITY: In production, set ADMIN_PASSWORD_HASH to a bcrypt hash instead of ADMIN_PASSWORD
# Generate with: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
ADMIN_EMAIL="admin@bizdak.com"
ADMIN_PASSWORD="change-me-on-first-run"
# ADMIN_PASSWORD_HASH="$2b$10$..."   ← use this in production

# DeepL Translation API (free tier: 500K chars/month)
# Get key at: https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_api_key_here
# Set to "paid" if using a DeepL paid plan (uses api.deepl.com instead of api-free.deepl.com)
# DEEPL_TIER=paid
